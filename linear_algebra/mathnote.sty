% ==============================================================
% § 5. Part 番号のローマ数字（文字詰め版）
% ==============================================================

% \tightromanpart{n}: 文字間を詰めた視覚的に均整のとれるローマ数字を出力
% グループ化は etoc が目次書き込み時に分断するのを防ぐため
\newcommand{\tightromanpart}[1]{%
  {%
  \ifcase#1%
  \or I%
  \or I\hspace{-1.2pt}I%
  \or I\hspace{-1.2pt}I\hspace{-1.2pt}I%
  \or I\hspace{-1.2pt}V%
  \or V%
  \or V\hspace{-1.2pt}I%
  \or V\hspace{-1.2pt}I\hspace{-1.2pt}I%
  \or V\hspace{-1.2pt}I\hspace{-1.2pt}I\hspace{-1.2pt}I%
  \or I\hspace{-1.2pt}X%
  \or X%
  \else\uppercase\expandafter{\romannumeral#1}%
  \fi
  }%
}

% \tightpartnumber: 現在の part カウンタを \tightromanpart で出力
% .toc への書き込み時にも番号がずれないよう \DeclareRobustCommand で定義
\DeclareRobustCommand{\tightpartnumber}{\tightromanpart{\value{part}}}
% \thepart の表示形式を詰めローマ数字に変更
\renewcommand{\thepart}{\tightromanpart{\value{part}}}

% ==============================================================
% § 6. ページレイアウト（余白・ヘッダー・フッター・脚注）
% ==============================================================

% geometry / bxpapersize はクラスファイルで設定済み
% 図を絶対位置に配置する（textpos パッケージ）
\RequirePackage[absolute,overlay]{textpos}

% ---- 柱（ヘッダー）のフォーマット ----
% 偶数ページ左: ページ番号 + Part タイトル
% 奇数ページ右: Section タイトル + ページ番号
\RequirePackage{fancyhdr}

% 現在の Part・Section タイトルを保持するグローバル変数
\newcommand{\CurrentPartTitle}{}
\newcommand{\CurrentSectionTitle}{}

% \part / \section を拡張してタイトルを \gdef で更新する
\makeatletter

% --- \part の拡張 ---
\let\origpart\part
\renewcommand{\part}{%
  \@ifstar{\part@star}{\@ifnextchar[{\part@opt}{\part@noopt}}%
}

% オプション引数なし版
\def\part@noopt#1{%
  % .toc 書き込み時に \numberline を強制付与（etoc との互換性のため）
  \let\saved@addcontentsline\addcontentsline
  \def\addcontentsline##1##2##3{%
    \saved@addcontentsline{##1}{##2}{\protect\numberline{\thepart}#1}%
    \let\addcontentsline\saved@addcontentsline
  }%
  \origpart{#1}%
  \let\addcontentsline\saved@addcontentsline
  \thispagestyle{empty}%  % part ページは柱を出さない
  \gdef\CurrentPartTitle{第\thepart 章\quad #1}%
}

% オプション引数あり版 [短縮タイトル]{表示タイトル}
\def\part@opt[#1]#2{%
  \let\saved@addcontentsline\addcontentsline
  \def\addcontentsline##1##2##3{%
    \saved@addcontentsline{##1}{##2}{\protect\numberline{\thepart}#1}%
    \let\addcontentsline\saved@addcontentsline
  }%
  \origpart[#1]{#2}%
  \let\addcontentsline\saved@addcontentsline
  \thispagestyle{empty}%
  \gdef\CurrentPartTitle{第\thepart 章\quad #1}%
}

% スター版（番号なし）
\def\part@star#1{%
  \origpart*{#1}%
  \thispagestyle{empty}%
  \gdef\CurrentPartTitle{#1}%
}

% --- \section の拡張 ---
\let\origsection\section
\renewcommand{\section}{%
  \@ifstar{\section@star}{\@ifnextchar[{\section@opt}{\section@noopt}}%
}

\def\section@noopt#1{%
  \origsection{#1}%
  \gdef\CurrentSectionTitle{\thesection\quad #1}%
}
\def\section@opt[#1]#2{%
  \origsection[#1]{#2}%
  \gdef\CurrentSectionTitle{\thesection\quad #1}%
}
\def\section@star#1{%
  \origsection*{#1}%
  \gdef\CurrentSectionTitle{#1}%
}

\makeatother

% ページスタイルの適用
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}  % ヘッダー下の罫線を消す

% 偶数ページ左柱：「p.〈番号〉　第〈n〉章　〈タイトル〉」
\fancyhead[LE]{%
  \footnotesize\strut
  p.\,\thepage\hspace{1.2\zw}\CurrentPartTitle
}
% 奇数ページ右柱：「〈節番号〉　〈タイトル〉 | p.〈番号〉」
\fancyhead[RO]{%
  \footnotesize\strut
  \CurrentSectionTitle\hspace{1\zw}|\hspace{1\zw}p.\,\thepage
}

% ---- 脚注のカスタマイズ ----
% 番号形式を「†1」「†2」... に変更
\renewcommand\thefootnote  {{\dag}\arabic{footnote}}
\renewcommand{\thempfootnote}{{\dag}\arabic{mpfootnote}}
% 脚注が改ページをまたぐのを極力避ける
\interfootnotelinepenalty=10000

% ==============================================================
% § 7. 見出しスタイル（titlesec）
% ==============================================================

\RequirePackage{titlesec}
\RequirePackage{picture}

% ---- 行の高さに自動追従する左肩の細角四角 ----
% #1（省略可）: 幅（デフォルト 1.05ex）  #2: 色名
\newcommand{\TitleSquareToText}[2][1.05ex]{%
  \begingroup
    \leavevmode
    \setbox0=\hbox{\strut}%
    \textcolor{#2}{\rule[-\dp\strutbox]{#1}{\dimexpr\ht\strutbox+\dp\strutbox\relax}}%
  \endgroup
}

% ---- Part（二重横線） ----
\titleformat{\part}[display]
  {\normalfont\LARGE\bfseries\centering\color{appleInk}}
  {\small\scshape\color{appleGray}第\thepart 章}
  {0.3ex}
  {}%
  [{%
     \vspace{0.6ex}%
     {\color{appleLine}\titlerule[1.2pt]}%  太線
     \nobreak\vspace{0.25ex}%
     {\color{appleLine}\titlerule[0.6pt]}%  細線
  }]

% ---- Section（下線 50%・\large） ----
% 意図的に "サブセクション" 相当の軽さに調整してある
% より重い見出し（下線 66%・\Large）にする場合は以下を差し替える:
%
%   \titleformat{\section}[block]
%     {\normalfont\Large\bfseries\color{appleInk}}
%     {}{0pt}
%     {%
%       \TitleSquareToText[1.05ex]{SectionTag}\hspace{0.6em}%
%       \thesection\quad
%     }%
%     [{%
%        \vspace*{-0.48\baselineskip}%
%        \noindent{\color{appleLine}\rule{0.66\linewidth}{0.8pt}}%
%        \nobreak\vspace{-0.10\baselineskip}%
%     }]
%
\titleformat{\section}[block]
  {\normalfont\large\bfseries\color{appleInk}}
  {}{0pt}
  {%
    \TitleSquareToText[0.95ex]{SubsectionTag}\hspace{0.55em}%
    \thesection\quad
  }%
  [{%
     \vspace*{-0.52\baselineskip}%
     \noindent{\color{appleLine}\rule{0.50\linewidth}{0.6pt}}%
     \nobreak\vspace{-0.18\baselineskip}%
  }]

% ---- Subsection（下線 42%・やや控えめ） ----
\titleformat{\subsection}[block]
  {\normalfont\large\bfseries\color{appleInk}}
  {}{0pt}
  {%
    \TitleSquareToText[0.90ex]{SubsubsectionTag}\hspace{0.50em}%
    \thesubsection\quad
  }%
  [{%
     \vspace*{-0.40\baselineskip}%
     \noindent{\color{appleLine}\rule{0.42\linewidth}{0.5pt}}%
     \nobreak\vspace{-0.16\baselineskip}%
  }]

% ==============================================================
% § 8. 目次（etoc — Apple 風デザイン）
% ==============================================================

\RequirePackage{etoc}

\makeatletter
\AtBeginDocument{%

  % 目次に表示する深さ（subsection まで）
  \etocsetnexttocdepth{subsection}

  % 目次ブロックの前後に TikZ でヘアラインを引き，中央に「目 次」を配置
  \etocsettocstyle{%
    \par\vspace{10pt}%
    \noindent\hspace*{-\leftskip}%
    \begin{tikzpicture}[x=\linewidth, baseline]
      \draw[line cap=round, line width=0.8pt, color=appleLine] (0,0) -- (1,0);
      \node[inner sep=2.5pt, outer sep=0pt, fill=appleCard] at (0.5,0)
        {\bfseries\Large\textcolor{appleInk}{目\kern0.35em 次}};
    \end{tikzpicture}%
    \vspace{8pt}%
  }{%
    \vspace{8pt}%
    \noindent\hspace*{-\leftskip}%
    \begin{tikzpicture}[x=\linewidth, baseline]
      \draw[line cap=round, line width=0.5pt, color=appleLine] (0,0) -- (1,0);
    \end{tikzpicture}%
    \vspace{12pt}%
  }

  % ---- Part エントリ（インデント=0，リーダー線あり） ----
  \etocsetstyle{part}
    {}
    {%
      \par\vskip11pt
      \parindent=0pt \leftskip=0pt
      \noindent
      \etoclink{%
        \bfseries\large\color{appleInk}%
        \makebox[1.5em][l]{\etocnumber}%
        \etocname
      }%
      \nobreak\leaders\hbox to .5em{\hss.\hss}\hfill \etocpage\par
      \vskip5.5pt
    }
    {}
    {}

  % ---- Section エントリ（インデント 30pt，リーダー線あり） ----
  \etocsetstyle{section}
    {\noindent}
    {%
      \vskip2.5pt
      \parindent=0pt
      \leftskip=30pt
      \noindent
      \etoclink{%
        \bfseries\normalsize\color{appleInk}%
        \makebox[2.0em][l]{\etocnumber}%
        \etocname
      }%
      \nobreak\leaders\hbox to .5em{\hss.\hss}\hfill \etocpage\par
      \vskip3.5pt
    }
    {}
    {}

  % ---- Subsection エントリ（インデント 56pt，ページ番号はカッコ付き） ----
  \etocsetstyle{subsection}
    {\noindent}
    {%
      \parindent=0pt
      \leftskip=56pt
      \rightskip=0pt plus 1fil
      \small
      \etoclink{%
        \makebox[2.0em][l]{\etocnumber}%
        \etocname
        \hspace{0.35em}%
        {(p.\etocpage)}%
      }%
      \hspace{1.35em plus 0.45em minus 0.15em}%
    }
    {}
    {}

}%
\makeatother

% ==============================================================
% § 9. tcolorbox — 定理環境
% ==============================================================

\RequirePackage[many]{tcolorbox}
\tcbuselibrary{breakable,skins,theorems,xparse,hooks}

% ---- 各環境のアクセント色エイリアス ----
% ここを変えるだけで全環境の配色を一括変更できる
\colorlet{acc@th}{appleInkGray}              % Theorem：ニュートラルな濃い灰
\colorlet{acc@pr}{appleGrayDark}             % Proposition：やや濃い灰
\colorlet{acc@co}{appleGray}                 % Corollary：中間灰
\colorlet{acc@ax}{appleInk}                  % Axiom：ほぼ黒（最も重い命題）
\colorlet{acc@de}{applePurple}               % Definition：紫
\colorlet{acc@le}{applePurple!75!appleInk}   % Lemma：定義より落ち着いた紫
\colorlet{acc@ex}{appleGrayLight}            % Example：軽めの灰
\colorlet{acc@qu}{applePurple!60!appleGray}  % Question：紫寄り灰

% ---- 共通ベーススタイル ----
% 白カード + 下端に薄い仕切り線 + 左に 2pt のアクセントバー
\tcbset{
  theo-base/.style={
    enhanced, breakable, sharp corners,
    boxrule=0pt, no shadow,
    colback=appleCard, colframe=appleCard, colbacktitle=appleCard,
    coltitle=appleInk, coltext=appleInk,
    fonttitle=\gtfamily\sffamily\bfseries\upshape,
    left*=1\zw, right*=1\zw, top=8pt, bottom=10pt,
    % 箱のすぐ下に薄い仕切り線（次の環境との視覚的区切り）
    borderline south={0.8pt}{-2pt}{appleLine},
    before={\par\vspace*{16pt}\noindent},
    after skip=18pt,
    before upper={\setlength{\parindent}{1\zw}},
    before lower={\setlength{\parindent}{1\zw}},
    % ページ先頭での継続時に上部スペースを確保
    pad at break=0pt,
    enlarge top at break by=12pt,
    enlarge bottom at break by=0pt
  },
  % mytheo: theo-base に左アクセントバーを追加（#1 = 色名）
  mytheo/.style n args={1}{
    theo-base,
    borderline west={2pt}{0pt}{#1}
  },
}

% ---- 各定理環境（subsection 内で共通カウンタを使用） ----
\newtcbtheorem[number within=subsection]{theorem}   {Theorem}    {mytheo={acc@th}}{th}
\newtcbtheorem[use counter from=theorem]{prop}      {Proposition}{mytheo={acc@pr}}{pr}
\newtcbtheorem[use counter from=theorem]{cor}       {Corollary}  {mytheo={acc@co}}{co}
\newtcbtheorem[use counter from=theorem]{axiom}     {Axiom}      {mytheo={acc@ax}}{ax}
\newtcbtheorem[use counter from=theorem]{definition}{Definition} {mytheo={acc@de}}{de}
\newtcbtheorem[use counter from=theorem]{lemma}     {Lemma}      {mytheo={acc@le}}{le}
\newtcbtheorem[use counter from=theorem]{example}   {Example}    {mytheo={acc@ex}}{ex}
\newtcbtheorem[use counter from=theorem]{question}  {Question}   {mytheo={acc@qu}}{qu}

% ---- 参照コマンド（\thref{ラベル} → 太字サンセリフの "Theorem 1.2"） ----
\newcommand{\thref} [1]{\textsf{\bfseries Theorem~\ref{th:#1}}}
\newcommand{\prref} [1]{\textsf{\bfseries Proposition~\ref{pr:#1}}}
\newcommand{\coref} [1]{\textsf{\bfseries Corollary~\ref{co:#1}}}
\newcommand{\axref} [1]{\textsf{\bfseries Axiom~\ref{ax:#1}}}
\newcommand{\deref} [1]{\textsf{\bfseries Definition~\ref{de:#1}}}
\newcommand{\lemref}[1]{\textsf{\bfseries Lemma~\ref{le:#1}}}
\newcommand{\exref} [1]{\textsf{\bfseries Example~\ref{ex:#1}}}
