% mathnote.sty
% LuaLaTeX / LuaHBTeX + mathnote クラス用のスタイルファイル
%
% 使い方（メインの .tex ファイル）:
%   \documentclass{mathnote}   % 文書構造（余白・フォント等）
%   \usepackage{mathnote}      % デザイン・マクロ・パッケージ追加

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{mathnote}[2026/06/27 math note style: design, macros, packages]

% ==============================================================
% § 1. 基本パッケージ
% ==============================================================

% luatexja / luatexja-fontspec / geometry はクラスファイルで読み込み済み
% .aux ファイル読み込み時のフック機構
\RequirePackage{auxhook}
% 画像の取り込み
\RequirePackage{graphicx}
% 画像・ボックスのサイズ調整
\RequirePackage{adjustbox}
% 複数行の comment 環境（\begin{comment}...\end{comment}）
\RequirePackage{comment}
% 単位表記（\SI{3}{\meter} 等）
\RequirePackage{siunitx}
% 化学式・反応式
\RequirePackage[version=4]{mhchem}  % \ce{H2O} 等
\RequirePackage{chemfig}             % 構造式の描画
\RequirePackage{chemformula}         % \ch{} コマンド

% ==============================================================
% § 2. 数学パッケージ
% ==============================================================

\RequirePackage{amsmath}    % align, gather, cases 等の数式環境
\RequirePackage{amsfonts}   % \mathbb, \mathfrak 等
\RequirePackage{amssymb}    % 各種数学記号
\RequirePackage{amsthm}     % proof 環境のベース（§17 でカスタマイズ）
\RequirePackage{bm}         % \bm{v} でベクトルの太字斜体
\RequirePackage{mathtools}  % amsmath の拡張（\coloneqq 等）
\RequirePackage{nccmath}    % \medmath, \mfrac 等の補助コマンド
\RequirePackage{empheq}     % 数式ブロック全体を囲む枠
\RequirePackage{oubraces}   % \overbrace / \underbrace の拡張
\RequirePackage{ifthen}     % 条件分岐（\adunderbrace 内で使用）
% \itembox, \screen 等の日本語向け枠環境
\RequirePackage{ascmac}

% ---- 絶対値・ノルムの自動サイズ調整デリミタ ----
% スター付き（\abs*{x}）で \left\right の自動サイズ調整
\DeclarePairedDelimiter{\abs} {\lvert}{\rvert}
\DeclarePairedDelimiter{\norm}{\lVert}{\rVert}

% ---- 分数のカスタマイズ ----
% \frac を displaystyle 優先の \bunsuu で上書きする
%   \bunsuu{分子}{分母}  ：常に \dfrac（displaystyle）ベース
%   \bunsuu*{分子}{分母} ：\mathchoice で数式スタイルに自動追従
%   \normalfrac{分子}{分母}：元の \frac を明示的に使いたい場合
\makeatletter

\let\oldfrac\frac

\DeclareRobustCommand{\bunsuu}{\@ifstar{\bunsuu@}{\@@bunsuu}}

% 通常版（常に \dfrac ベース）：分子・分母を微調整してバランスを改善
\def\@@bunsuu#1#2{%
  \dfrac{%
    \lower.16ex\hbox{$\m@th\displaystyle\mkern1mu#1\mkern1mu$}%
  }{%
    \lower-.036ex\hbox{$\m@th\displaystyle\mkern1mu#2\mkern1mu$}%
  }%
}

% textstyle 用（インライン数式内での分数）
\def\tbunsuu#1#2{%
  \tfrac{%
    \mkern1mu#1\mkern1mu
  }{%
    \lower-.05ex\hbox{$\m@th\scriptstyle\mkern1mu#2\mkern1mu$}%
  }%
}

% スター版：\mathchoice で display / text / script / scriptscript に自動追従
\def\bunsuu@#1#2{%
  \mathchoice
    {\@@bunsuu{#1}{#2}}%
    {\tbunsuu{#1}{#2}}%
    {\oldfrac{\mkern1mu#1\mkern1mu}{\mkern1mu#2\mkern1mu}}%
    {\oldfrac{\mkern1mu#1\mkern1mu}{\mkern1mu#2\mkern1mu}}%
}

\renewcommand{\frac}[2]{\bunsuu{#1}{#2}}
% 元の \frac を明示的に使う場合
\newcommand{\normalfrac}[2]{\oldfrac{#1}{#2}}

\makeatother

% ---- \sum・\prod を 0.97 倍に縮小 ----
% 本文サイズに対して記号が大きく見えすぎるのを補正する
\makeatletter

\let\orgsum\sum
\let\orgprod\prod

\DeclareRobustCommand{\sum}{%
  \mathop{\mathchoice
    {\vcenter{\hbox{\scalebox{0.97}{$\displaystyle\orgsum$}}}}%
    {\vcenter{\hbox{\scalebox{0.97}{$\textstyle\orgsum$}}}}%
    {\vcenter{\hbox{\scalebox{0.97}{$\scriptstyle\orgsum$}}}}%
    {\vcenter{\hbox{\scalebox{0.97}{$\scriptscriptstyle\orgsum$}}}}%
  }\limits%
}

\DeclareRobustCommand{\prod}{%
  \mathop{\mathchoice
    {\vcenter{\hbox{\scalebox{0.97}{$\displaystyle\orgprod$}}}}%
    {\vcenter{\hbox{\scalebox{0.97}{$\textstyle\orgprod$}}}}%
    {\vcenter{\hbox{\scalebox{0.97}{$\scriptstyle\orgprod$}}}}%
    {\vcenter{\hbox{\scalebox{0.97}{$\scriptscriptstyle\orgprod$}}}}%
  }\limits%
}

\makeatother

% ---- 数式周りの縦スペースを微調整 ----
\setlength{\abovedisplayskip}{5pt}
\setlength{\belowdisplayskip}{3pt}

