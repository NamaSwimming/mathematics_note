% ---- 微分・高階微分 ----
\newcommand{\dash}  [1]{#1^\prime}
\newcommand{\ddash} [1]{#1^{\prime\prime}}
\newcommand{\dddash}[1]{#1^{\prime\prime\prime}}
\newcommand{\hodash}[2]{#2^{(#1)}}  % 使い方: \hodash{n}{f} → f^{(n)}

% enumerate のラベルを (1)(2)... に変更
\renewcommand{\labelenumi}{(\arabic{enumi})}

% ---- 執筆中マーカー ----
\newcommand{\draftnote}[1]{%
  \begin{center}\textbf{\textcolor{red}{執筆中：~#1}}\end{center}}

% ---- 数学演算子 ----
\newcommand{\kaijou}{\ensuremath{\mkern1mu!\mkern1mu}}  % 階乗 !
\newcommand{\dom}{\mathop{\mathrm{dom}}\nolimits}       % 定義域
\newcommand{\ran}{\mathop{\mathrm{ran}}\nolimits}       % 値域
\newcommand{\relmiddle}[1]{\,\middle|\,}                % 集合の条件部 |

\DeclareMathOperator{\Ker} {Ker}
\DeclareMathOperator{\sgn} {sgn}
\DeclareMathOperator{\rank}{rank}

% ---- 不等号を二重線に統一 ----
\renewcommand{\le} {\leqq}
\renewcommand{\ge} {\geqq}
\renewcommand{\leq}{\leqq}
\renewcommand{\geq}{\geqq}

% ---- 《題》スタイルの強調 ----
\newcommand\kakko[1]{\noindent\textbf{《#1》}}

% ---- underbrace のラベルが長いときに自動的に中央揃えにする ----
\newlength{\wdTempA}
\newlength{\wdTempB}
\newcommand{\adunderbrace}[2]{%
  \settowidth{\wdTempA}{$#1$}%
  \settowidth{\wdTempB}{${\scriptstyle #2}$}%
  \ifthenelse{\wdTempA<\wdTempB}{%
    \hspace*{.5\wdTempA}\hspace*{-.5\wdTempB}%
    \underbrace{#1}_{#2}%
    \hspace*{.5\wdTempA}\hspace*{-.5\wdTempB}%
  }{%
    \underbrace{#1}_{#2}%
  }%
}

% ---- 丸付き文字（\ctext{A} → 丸囲み A） ----
\newcommand{\ctext}[1]{\raise0.2ex\hbox{\textcircled{\scriptsize{#1}}}}

% ---- 横罫線（\HRule{太さ}） ----
\newcommand{\HRule}[1]{\rule{\linewidth}{#1}}

% \qty を siunitx の \SI に置換（amsmath との衝突回避）
\AtBeginDocument{\RenewCommandCopy\qty\SI}

% ---- \chikan: 置換の表記コマンド ----
% \chikan{x,y}{a,b}  → 置換表示（全要素）
% \chikan*{x,y}{a,b} → 不動点（上下一致）を自動的に除いた置換表示
\RequirePackage{expl3}
\ExplSyntaxOn
\NewDocumentCommand{\chikan}{s m m}{
  \group_begin:
  \clist_set:Nn \l_tmpa_clist {#2}
  \clist_set:Nn \l_tmpb_clist {#3}
  \IfBooleanTF{#1}
  {
    % スターあり: 上下一致（不動点）を除いてから出力
    \seq_clear:N \l_tmpa_seq
    \seq_clear:N \l_tmpb_seq
    \int_step_inline:nn { \clist_count:N \l_tmpa_clist } {
      \str_set:Nx \l_tmpa_str { \clist_item:Nn \l_tmpa_clist {##1} }
      \str_set:Nx \l_tmpb_str { \clist_item:Nn \l_tmpb_clist {##1} }
      \str_if_eq:NNF \l_tmpa_str \l_tmpb_str {
        \seq_put_right:NV \l_tmpa_seq \l_tmpa_str
        \seq_put_right:NV \l_tmpb_seq \l_tmpb_str
      }
    }
    % 全て不動点の場合は元のリストを安全に出力
    \int_compare:nNnTF { \seq_count:N \l_tmpa_seq } > { 0 }
      { \__chikan_render_seq:NN  \l_tmpa_seq  \l_tmpb_seq  }
      { \__chikan_render_clist:NN \l_tmpa_clist \l_tmpb_clist }
  }
  {
    % スターなし: そのまま出力
    \__chikan_render_clist:NN \l_tmpa_clist \l_tmpb_clist
  }
  \group_end:
}
\cs_new:Nn \__chikan_render_clist:NN {
  \left(
  \begin{array}{ *{ \clist_count:N #1 } {c} }
    \clist_use:Nn #1 { & } \\
    \clist_use:Nn #2 { & }
  \end{array}
  \right)
}
\cs_new:Nn \__chikan_render_seq:NN {
  \left(
  \begin{array}{ *{ \seq_count:N #1 } {c} }
    \seq_use:Nn #1 { & } \\
    \seq_use:Nn #2 { & }
  \end{array}
  \right)
}
\ExplSyntaxOff

