% 右へずらす量はオプション引数で指定できるようにする
% 例：\begin{aleftbar}[1em] ... \end{aleftbar}
\newenvironment{aleftbar}[1][0.0em]{%
  \par\begingroup
  \setlength{\FrameRule}{0.4pt}% 線の太さ
  \setlength{\FrameSep}{0.0em}% 線と本文の間（詰めるならここ）
  \noindent\hspace*{#1}%
  \begin{minipage}{\dimexpr\linewidth-#1\relax}%
    \begin{leftbar}%
    \ignorespaces
}{%
    \end{leftbar}%
  \end{minipage}%
  \par\endgroup
}




