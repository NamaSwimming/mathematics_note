\newcommand{\tightromanpart}[1]{%
  {% <- 追加：etocによる分断を防ぐためのグループ化
  \ifcase#1%
  \or I% <- 1
  \or I\hspace{-1.2pt}I% <- 2
  \or I\hspace{-1.2pt}I\hspace{-1.2pt}I% <- 3
  \or I\hspace{-1.2pt}V% <- 4
  \or V% <- 5
  \or V\hspace{-1.2pt}I% <- 6
  \or V\hspace{-1.2pt}I\hspace{-1.2pt}I% <- 7
  \or V\hspace{-1.2pt}I\hspace{-1.2pt}I\hspace{-1.2pt}I% <- 8
  \or I\hspace{-1.2pt}X% <- 9
  \or X% <- 10
  \else\uppercase\expandafter{\romannumeral#1}%
  \fi
  }% <- 追加
}

\newcommand{\tightpartnumber}{\tightromanpart{\value{part}}}

% 表示用の詰めたローマ数字（part番号）
% #1 に数値を渡す形にして、.toc に書き込まれても番号がずれないようにする。
\DeclareRobustCommand{\tightpartnumber}{\tightromanpart{\value{part}}}
\renewcommand{\thepart}{\tightromanpart{\value{part}}}

