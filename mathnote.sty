\RequirePackage{pagecolor} % 背景色を変更するためのパッケージ

% タイトルページ（Apple風：白地・黒字＋薄灰のヘアライン）
% 依存: xcolor, tikz（既に読み込んでいればOK）
% 配色は appleInk / appleInkGray / appleLine を利用
\newcommand{\tituloum}[5]{%
  \begin{titlepage}
    \thispagestyle{empty}%
    \pagecolor{white}% タイトル面は純白
    \color{appleInk}% 文字は黒系

    \vspace*{1.8\baselineskip}%

    \begin{center}
      % --- Eyebrow（小さな上部ラベル：シリーズ名など） ---
      {\small\sffamily\bfseries\color{appleGray} #3\par}

      \vspace{0.75\baselineskip}

      % --- Hero Title（主タイトル） ---
      % 和文でも潰れにくいようサンセリフ＋太字．行送りはやや広め．
      {\fontsize{34pt}{40pt}\selectfont\sffamily\bfseries #1\par}

      \vspace{0.7\baselineskip}

      % --- Hairline（Apple風の細い区切り線：中央 66% 幅） ---
      \begin{tikzpicture}[x=\linewidth, y=1pt]
        \draw[line cap=round, line width=0.8pt, color=appleLine] (0.17,0) -- (0.83,0);
      \end{tikzpicture}

      % --- サブコピー（淡色で） ---
      \vspace{0.9\baselineskip}
      {\large\sffamily\itshape\color{appleInkGray} #4\par}

      \vfill

      \begin{flushright}
      % --- 著者・日付/版情報（下部ブロック） ---
      {\normalsize\sffamily\bfseries #2\par}
      \vspace{0.35\baselineskip}
      {\footnotesize\sffamily\color{appleGray} #5\par}
      \end{flushright}
    \end{center}

  \end{titlepage}%
  % ※本文で applePaper 等の地色を使う場合は，必要に応じてここで戻してください．
  % \pagecolor{applePaper}
}


\RequirePackage{array}
\RequirePackage{expl3}

\ExplSyntaxOn
\NewDocumentCommand{\chikan}{s m m}{
    \group_begin:
    \clist_set:Nn \l_tmpa_clist {#2}
    \clist_set:Nn \l_tmpb_clist {#3}
    
    % スター（*）が付いているか判定
    \IfBooleanTF{#1}
    {
        % 【スターあり】不動点（上下一致）を削除するロジック
        \seq_clear:N \l_tmpa_seq
        \seq_clear:N \l_tmpb_seq
        
        \int_step_inline:nn { \clist_count:N \l_tmpa_clist } {
            \str_set:Nx \l_tmpa_str { \clist_item:Nn \l_tmpa_clist {##1} }
            \str_set:Nx \l_tmpb_str { \clist_item:Nn \l_tmpb_clist {##1} }
            
            \str_if_eq:NNF \l_tmpa_str \l_tmpb_str {
                \seq_put_right:NV \l_tmpa_seq \l_tmpa_str
                \seq_put_right:NV \l_tmpb_seq \l_tmpb_str
            }
        }
        
        % 全て削除されて空になった場合は，安全のため元のリストを表示
        \int_compare:nNnTF { \seq_count:N \l_tmpa_seq } > { 0 }
        { \__chikan_render_seq:NN \l_tmpa_seq \l_tmpb_seq }
        { \__chikan_render_clist:NN \l_tmpa_clist \l_tmpb_clist }
    }
    {
        % 【スターなし】そのまま出力
        \__chikan_render_clist:NN \l_tmpa_clist \l_tmpb_clist
    }
    \group_end:
}

% 内部用：clist（カンマ区切り）を描画する補助関数
\cs_new:Nn \__chikan_render_clist:NN {
    \left(
    \begin{array}{ *{ \clist_count:N #1 } {c} }
        \clist_use:Nn #1 { & } \\
        \clist_use:Nn #2 { & }
    \end{array}
    \right)
}

% 内部用：seq（選別済みリスト）を描画する補助関数
\cs_new:Nn \__chikan_render_seq:NN {
    \left(
    \begin{array}{ *{ \seq_count:N #1 } {c} }
        \seq_use:Nn #1 { & } \\
        \seq_use:Nn #2 { & }
    \end{array}
    \right)
}
\ExplSyntaxOff

